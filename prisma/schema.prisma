// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// generator zod {
//     provider = "prisma-zod-generator"
// }

model User {
  id         Int      @id @default(autoincrement()) @map("user_id")
  email      String   @unique @db.VarChar(100)
  password   String   @db.VarChar(24)
  profile    Profile?
  reviews    Review[]
  created_at DateTime @default(now()) @ignore

  @@map("users")
}

model Profile {
  id         Int      @id @map("profile_id")
  firstName  String   @db.VarChar(50)
  lastName   String   @db.VarChar(50)
  avatar     String   @db.VarChar(255)
  user       User     @relation(fields: [id], references: [id])
  created_at DateTime @default(now()) @ignore

  @@map("profiles")
}

model Film {
  id         Int      @id @default(autoincrement()) @map("film_id")
  title      String   @unique @db.VarChar(255)
  year       DateTime @default(now()) @map("release_year")
  director   String   @db.VarChar(255)
  duration   Int
  poster     String   @db.VarChar(255)
  rate       Decimal  @db.Decimal(2, 1)
  genres     Genre[]
  reviews    Review[]
  created_at DateTime @default(now()) @ignore

  @@map("films")
}

model Genre {
  id         Int      @id @default(autoincrement()) @map("genre_id")
  name       String   @unique @db.VarChar(255)
  film       Film[]
  created_at DateTime @default(now()) @ignore

  @@map("genres")
}

model Review {
  userId     Int      @map("user_id")
  filmId     Int      @map("film_id")
  user       User?    @relation(fields: [userId], references: [id])
  film       Film?    @relation(fields: [filmId], references: [id])
  review     String   @db.Text
  created DateTime    @default(now()) @map("created_at")

  @@id([userId, filmId])
  @@map("reviews")
}

