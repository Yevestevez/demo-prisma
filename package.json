{
    "name": "demo-prisma",
    "version": "1.0.0",
    "description": "Demo de backend con Express, Node, Postgres y Prisma del Curso DATW 2026",
    "main": "index.ts",
    "packageManager": "pnpm@11.1.1",
    "scripts": {
        "start": "cross-env NODE_ENV=prod node ./src/index.ts",
        "dev": "node --watch --env-file=.env ./src/index.ts",
        "ts:check": "tsc --noEmit",
        "seed:dev": "prisma db seed",
        "db:push:test": "prisma db push --config prisma.test.config.ts",
        "db:seed:test": "prisma db seed --config prisma.test.config.ts",
        "seed:test": "pnpm run db:push:test && pnpm run db:seed:test",
        "test": "vitest",
        "test:coverage": "vitest run --coverage",
        "e2e": "vitest -c vitest.config.e2e.ts --maxConcurrency 1"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/DATW-2026/demo-prisma"
    },
    "type": "module",
    "dependencies": {
        "@prisma/adapter-pg": "^7.7.0",
        "@prisma/client": "^7.7.0",
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.6",
        "cross-env": "^10.0.0",
        "debug": "^4.4.3",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "gray-matter": "^4.0.3",
        "jsonwebtoken": "^9.0.3",
        "marked": "^18.0.2",
        "morgan": "^1.10.1",
        "pg": "^8.20.0",
        "serve-static": "^2.2.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/cors": "^2.8.19",
        "@types/debug": "^4.1.13",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/marked": "^5.0.2",
        "@types/morgan": "^1.9.10",
        "@types/node": "^25.6.0",
        "@types/pg": "^8.20.0",
        "@types/serve-static": "^2.2.0",
        "@types/supertest": "^7.2.0",
        "@vitest/coverage-v8": "^4.1.5",
        "eslint": "^10.0.3",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "prisma": "^7.7.0",
        "supertest": "^7.2.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.1",
        "vitest": "^4.1.5",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/user-event": "^14.6.1",
        "@types/jsdom": "^28.0.3"
    },
    "prettier": {
        "singleQuote": true
    }
}
